{
  "name": "agent-workflow-template (Dockerfile standard mode)",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {},
  "containerEnv": {
    "UV_VERSION": "0.5.24"
  },
  "remoteEnv": {
    "OAI_API_KEY": "${localEnv:OAI_API_KEY}",
    "OAI_BASE_URL": "${localEnv:OAI_BASE_URL}",
    "OPENROUTER_API_KEY": "${localEnv:OPENROUTER_API_KEY}",
    "OBSIDIAN_VAULT_ROOT": "/obsidian/vault"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "python.defaultInterpreterPath": "/workspaces/${localWorkspaceFolderBasename}/.venv/bin/python",
        "python.terminal.activateEnvironment": false
      },
      "extensions": [
        "alefragnani.project-manager",
        "bierner.color-info",
        "chouzz.vscode-better-align",
        "christian-kohler.path-intellisense",
        "dbaeumer.vscode-eslint",
        "eamodio.gitlens",
        "emanuelebartolesi.vscode-copilot-insights",
        "esbenp.prettier-vscode",
        "github.copilot",
        "github.copilot-chat",
        "github.vscode-github-actions",
        "github.vscode-pull-request-github",
        "gruntfuggly.todo-tree",
        "gxl.git-graph-3",
        "johnpapa.vscode-peacock",
        "louiswt.regexp-preview",
        "mechatroner.rainbow-csv",
        "ms-azuretools.vscode-containers",
        "ms-python.autopep8",
        "ms-python.debugpy",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.vscode-python-envs",
        "oderwat.indent-rainbow",
        "openai.chatgpt",
        "rangav.vscode-thunder-client",
        "ritwickdey.liveserver",
        "streetsidesoftware.code-spell-checker",
        "usernamehw.errorlens",
        "vscode-icons-team.vscode-icons",
        "yzhang.markdown-all-in-one",
        "ivyhouse-local.ivyhouse-terminal-pty",
        "ivyhouse-local.ivyhouse-terminal-fallback"
      ]
    }
  },
  "remoteUser": "vscode",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "mounts": [
    "source=${localEnv:USERPROFILE}/OneDrive/4-管理專用/Jonas/AI生成/程式/ObsidianVault,target=/obsidian/vault,type=bind"
  ],
  "postCreateCommand": "bash .agent/runtime/scripts/devcontainer/post_create.sh",
  "runArgs": [
    "--add-host=host.docker.internal:host-gateway"
  ]
}
